# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Portfolio review — live trading
# false (default): full dry run, review + actions.json only, nothing sent to Robinhood
# true: engine-mandated SELL exits auto-approved and executed via Robinhood MCP
# BUY actions are never auto-executed regardless of this flag
LIVE_TRADING=false

# Telegram alerts (optional but strongly recommended for cloud/automated runs)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
